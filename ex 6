import 'package:flutter/material.dart';

void main() {
  runApp(MyApp());
}

List<String> cart = [];

// Custom Colors
const Color primaryColor = Color.fromRGBO(87, 118, 177, 1);
const Color lightColor = Color.fromRGBO(174, 190, 221, 1);

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      theme: ThemeData(
        primaryColor: primaryColor,
        scaffoldBackgroundColor: lightColor,
        appBarTheme: AppBarTheme(
          backgroundColor: primaryColor,
        ),
        elevatedButtonTheme: ElevatedButtonThemeData(
          style: ElevatedButton.styleFrom(
            backgroundColor: primaryColor,
          ),
        ),
      ),
      home: HomePage(),
    );
  }
}

class HomePage extends StatelessWidget {
  final List<String> products = ["Shoes", "T-Shirt", "Watch","Pants"];

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text("Online Shop"),
        actions: [
          IconButton(
            icon: Icon(Icons.shopping_cart),
            color : Colors.white,
            onPressed: () {
              Navigator.push(
                context,
                MaterialPageRoute(builder: (context) => CartPage()),
              );
            },
          )
        ],
      ),
      body: Container(
        color: lightColor,
        child: ListView(
          children: products.map((item) {
            return Card(
              color: Colors.white,
              child: ListTile(
                title: Text(item),
                trailing: ElevatedButton(
                  child: Text("Add",style: TextStyle(
    color: Colors.white,
  ),),
                  onPressed: () {
                    cart.add(item);
                    ScaffoldMessenger.of(context).showSnackBar(
                      SnackBar(content: Text("$item added to cart")),
                    );
                  },
                ),
              ),
            );
          }).toList(),
        ),
      ),
    );
  }
}

class CartPage extends StatefulWidget {
  @override
  _CartPageState createState() => _CartPageState();
}

class _CartPageState extends State<CartPage> {
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text("Cart"),
      ),
      body: Container(
        color: lightColor,
        child: cart.isEmpty
            ? Center(
                child: Text(
                  "Cart is Empty",
                  style: TextStyle(fontSize: 18,color: Color.white),
                ),
              )
            : ListView.builder(
                itemCount: cart.length,
                itemBuilder: (context, index) {
                  return Card(
                    color: Colors.white,
                    child: ListTile(
                      title: Text(cart[index],style: TextStyle(
    color: Colors.white,
  ),),
                      trailing: ElevatedButton(
                        child: Text("Remove",style: TextStyle(
    color: Colors.white,
  ),),
                        onPressed: () {
                          setState(() {
                            cart.removeAt(index);
                          });

                          ScaffoldMessenger.of(context).showSnackBar(
                            SnackBar(
                              content:
                                  Text("Item removed from cart"),
                            ),
                          );
                        },
                      ),
                    ),
                  );
                },
              ),
      ),
    );
  }
}
